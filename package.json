{
  "name": "pomodoro-timer",
  "version": "1.0.0",
  "description": "Menu bar Pomodoro timer desktop app built with Electron, React, Vite, and TypeScript.",
  "main": "dist/main/main.js",
  "workspaces": [
    "app/renderer"
  ],
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:watch:main\" \"npm:watch:preload\" \"npm:dev:electron\"",
    "dev:renderer": "cd app/renderer && npm run dev",
    "watch:main": "tsc -p app/main/tsconfig.json --watch",
    "watch:preload": "tsc -p app/preload/tsconfig.json --watch",
    "dev:electron": "wait-on dist/main/main.js dist/preload/index.js && cross-env NODE_ENV=development ELECTRON_DISABLE_GPU=1 electron . --disable-gpu",
    "build": "npm run build:renderer && npm run build:main && npm run build:preload && electron-builder -c build/electron-builder.yml",
    "build:renderer": "cd app/renderer && npm run build",
    "build:main": "tsc -p app/main/tsconfig.json",
    "build:preload": "tsc -p app/preload/tsconfig.json",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.base.json --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^32.2.7",
    "electron-builder": "^25.0.5",
    "eslint": "^10.0.2",
    "prettier": "^3.4.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "electron-liquid-glass": "^1.1.1"
  }
}
